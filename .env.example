# CONK Drop — environment variables
# Copy to .env.local for development

# CONK Protocol (update to v14 after prod deploy)
VITE_CONK_PACKAGE=0x6eca0063f930674f26a4a4593a7ef5ed487e21f31caafe74290ab5df88478cc6

# zkProxy (Cloudflare Worker)
VITE_ZKPROXY_URL=https://conk-zkproxy-v2.italktonumbers.workers.dev

# Sui RPC (routes through zkProxy by default; swap to direct Tatum endpoint for prod)
VITE_SUI_RPC=https://conk-zkproxy-v2.italktonumbers.workers.dev/sui

# Google OAuth (for zkLogin) — must match authorized origins in Google Cloud Console
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
